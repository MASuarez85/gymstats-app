# Postgres (Railway/Render te dan esta URL directamente al crear la base)
DATABASE_URL=postgresql://usuario:password@host:5432/gymstats

# Redis (cache). Local con Docker: redis://localhost:6379
# En Railway/Render/Upstash te dan la URL completa al crear el servicio.
REDIS_URL=redis://localhost:6379

# Clave de la API de Anthropic (la misma que ya usabas en Vercel)
ANTHROPIC_API_KEY=sk-ant-tu-clave-aqui

# Secreto para firmar los JWT propios que emite este backend.
# Generalo con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambiame-por-un-valor-random-largo

# Bundle ID de la app iOS (Sign in with Apple lo valida contra esto), ej: com.tuusuario.gymstats
APPLE_BUNDLE_ID=com.tuusuario.gymstats

# Puerto local (Railway/Render lo pisan con su propia variable PORT)
PORT=3001

# Habilita POST /auth/dev, que da un token sin pasar por Sign in with Apple.
# Solo para probar el CRUD en local con curl/Postman. Dejar en false (o borrar la
# variable) en cualquier deploy real.
ALLOW_DEV_AUTH=true
