// Schema de Postgres para GymStats.
// Reemplaza el localStorage del frontend original: cada tabla espeja una
// de las claves que antes se guardaban en el navegador (ver README del repo).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "logging"]
}

model User {
  id            String   @id @default(uuid())
  appleUserId   String   @unique @map("apple_user_id")
  email         String?
  createdAt     DateTime @default(now()) @map("created_at")

  // Perfil editable por el usuario (pantalla "Editar perfil").
  displayName String?   @map("display_name")
  height      Float? // cm
  weight      Float? // kg
  goal        String? // 'Fuerza' | 'Hipertrofia' | 'Resistencia' | 'Salud general'
  birthdate   DateTime? @db.Date

  // Prueba gratuita de 1 mes desde el alta; luego se desactivan las pestañas
  // pagas salvo que subscriptionActive sea true (billing real: fase futura).
  trialStartedAt     DateTime @default(now()) @map("trial_started_at")
  subscriptionActive Boolean  @default(false) @map("subscription_active")

  entries            Entry[]
  dayPlans           DayPlan[]
  routines           Routine[]
  routineAssignments RoutineAssignment[]
  routineProgress    RoutineProgress[]
  visionCorrections  VisionCorrection[]

  @@map("users")
  @@schema("public")
}

model Entry {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  exercise    String
  muscleGroup String   @map("muscle_group")
  date        DateTime @db.Date
  createdAt   DateTime @default(now()) @map("created_at")
  // Comparten blockId dos (o más) entries cargadas como superserie: mismo grupo
  // muscular, distintas máquinas, en la misma "ronda" de entrenamiento. Null
  // para un ejercicio suelto, como era antes.
  blockId     String?  @map("block_id")

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sets EntrySet[]

  @@index([userId, date])
  @@index([userId, exercise])
  @@index([userId, blockId])
  @@map("entries")
  @@schema("public")
}

model EntrySet {
  id      String @id @default(uuid())
  entryId String @map("entry_id")
  weight  Float
  reps    Int
  order   Int

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@map("entry_sets")
  @@schema("public")
}

// Grupo(s) muscular(es) planificado(s) para un día puntual (calendario). Antes
// era un grupo por día (unique en userId+date); ahora puede haber varias filas
// para el mismo día, una por grupo muscular, para permitir días de entrenamiento
// combinados (ej: Pecho + Tríceps).
model DayPlan {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  date        DateTime @db.Date
  muscleGroup String   @map("muscle_group")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, muscleGroup])
  @@map("day_plans")
  @@schema("public")
}

model Routine {
  id     String @id @default(uuid())
  userId String @map("user_id")
  name   String

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises RoutineExercise[]
  assignments RoutineAssignment[]

  @@index([userId])
  @@map("routines")
  @@schema("public")
}

model RoutineExercise {
  id          String @id @default(uuid())
  routineId   String @map("routine_id")
  name        String
  muscleGroup String @map("muscle_group")
  targetSets  Int    @map("target_sets")
  targetReps  Int    @map("target_reps")
  order       Int

  routine  Routine            @relation(fields: [routineId], references: [id], onDelete: Cascade)
  progress RoutineProgress[]

  @@map("routine_exercises")
  @@schema("public")
}

// Rutina asignada a una fecha puntual del calendario.
model RoutineAssignment {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  date      DateTime @db.Date
  routineId String   @map("routine_id")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  routine Routine @relation(fields: [routineId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("routine_assignments")
  @@schema("public")
}

// Checklist de progreso: qué ejercicios de la rutina asignada ya se hicieron ese día.
model RoutineProgress {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  date       DateTime @db.Date
  exerciseId String   @map("exercise_id")
  done       Boolean  @default(true)

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise RoutineExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([userId, date, exerciseId])
  @@map("routine_progress")
  @@schema("public")
}

// Correcciones que el usuario hace a mano sobre lo que detectó la IA al
// fotografiar una máquina (ej: "esto es prensa de pierna, no press de banca").
// Las últimas correcciones de cada usuario se le pasan como contexto al modelo
// en el próximo análisis de foto, para que no repita el mismo error.
model VisionCorrection {
  id                   String   @id @default(uuid())
  userId               String   @map("user_id")
  originalExercise     String   @map("original_exercise")
  originalMuscleGroup  String   @map("original_muscle_group")
  correction           String
  createdAt            DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("vision_corrections")
  @@schema("public")
}

// --- Esquema "logging": separado del resto de los datos de la app para
// trazabilidad y diagnóstico (requests y errores), sin mezclarse con las
// tablas de negocio de arriba.

model RequestLog {
  id         String   @id @default(uuid())
  requestId  String   @map("request_id")
  method     String
  path       String
  statusCode Int      @map("status_code")
  durationMs Int      @map("duration_ms")
  userId     String?  @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([userId])
  @@map("request_logs")
  @@schema("logging")
}

model ErrorLog {
  id        String   @id @default(uuid())
  requestId String?  @map("request_id")
  source    String // 'http' | 'anthropic' | otros orígenes futuros
  message   String
  stack     String?
  context   Json?
  userId    String?  @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([source])
  @@map("error_logs")
  @@schema("logging")
}
